{
  "name": "ntfy Server",
  "version": "1.5.0",
  "slug": "ntfy_server",
  "description": "Privater ntfy-Server mit Reset-Funktion",
  "arch": ["aarch64", "amd64", "armhf", "armv7"],
  "startup": "services",
  "boot": "auto",
  "host_network": true,
  "options": {
    "base_url": "https://",
    "listen_port": 8000,
    "auth_default_access": "deny-all",
    "admin_user": "admin",
    "admin_password": "dein_sicheres_passwort",
    "enable_web_ui": false,
    "reset_data": false,
    "users": []
  },
  "schema": {
    "base_url": "str",
    "listen_port": "int(1,65535)",
    "auth_default_access": "list(read-write|read-only|deny-all)",
    "admin_user": "str",
    "admin_password": "password",
    "enable_web_ui": "bool",
    "reset_data": "bool",
    "users": [
      {
        "username": "str",
        "password": "password",
        "topic": "str"
      }
    ]
  }
}
